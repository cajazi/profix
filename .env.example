# ─────────────────────────────────────────────────────────────
# ProFix — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Paystack ──────────────────────────────────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────
VITE_APP_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────
# The following are for Edge Functions ONLY
# Set via: supabase secrets set PAYSTACK_SECRET=...
# NEVER put these in any VITE_ variable
# ─────────────────────────────────────────────────────────────

# PAYSTACK_SECRET=sk_live_xxxxxxxxxxxx
# PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx